# ============================================================
# CtrlAltStock Blog Bot — Environment Variables
# Copy this file to .env and fill in your values
# NEVER commit .env to Git (it's in .gitignore)
# ============================================================

# ---- AI Provider ----
# "openrouter" (recommended), "openai", or "ollama"
AI_PROVIDER=openrouter

# OpenRouter API key (https://openrouter.ai/keys)
OPENROUTER_API_KEY=sk-or-v1-...

# Free models (https://openrouter.ai/openrouter/free — append :free to model ID):
#   meta-llama/llama-3.3-70b-instruct:free  (best for writing — recommended)
#   deepseek/deepseek-chat:free
#   google/gemini-2.0-flash-exp:free
OPENROUTER_MODEL=meta-llama/llama-3.3-70b-instruct:free

# OpenAI Direct (only needed if AI_PROVIDER=openai)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o

# Ollama (if running locally on your NAS)
OLLAMA_BASE_URL=http://192.168.1.X:11434
OLLAMA_MODEL=llama3

# ---- Reddit API ----
# Register at: https://www.reddit.com/prefs/apps (choose "script" type)
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=CtrlAltStock/1.0 by u/YOUR_REDDIT_USERNAME

# ---- Amazon Affiliate ----
# PA-API 5.0 credentials (https://affiliate-program.amazon.co.uk/assoc_credentials/home)
AMAZON_ACCESS_KEY=
AMAZON_SECRET_KEY=
AMAZON_PARTNER_TAG=ctrlaltstock-21
AMAZON_REGION=uk
# Marketplace (UK = webservices.amazon.co.uk, US = webservices.amazon.com)
AMAZON_MARKETPLACE=webservices.amazon.co.uk

# ---- Unsplash (free images) ----
# Register at: https://unsplash.com/developers
UNSPLASH_ACCESS_KEY=

# ---- Git / Repo ----
# Absolute path to the repo on your NAS/VPS
REPO_PATH=/path/to/ctrlaltstock-frontend

# Git remote and branch
GIT_REMOTE=origin
GIT_BRANCH=main

# ---- Netlify / Cloudflare Pages Build Hook ----
# Paste your build hook URL here (optional — git push triggers it automatically on CF/Netlify)
BUILD_HOOK_URL=

# ---- Discord Notifications ----
# Webhook URL for admin notifications (success/failure alerts)
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/YOUR_WEBHOOK

# ---- Bot Behaviour ----
# How many articles to generate per run (usually 1 per hour)
ARTICLES_PER_RUN=1

# Minimum upvotes for Reddit post to be considered
REDDIT_MIN_UPVOTES=20

# Hours to look back in RSS feeds
RSS_LOOKBACK_HOURS=2

# Minimum article word count target
ARTICLE_MIN_WORDS=800
ARTICLE_MAX_WORDS=1200
